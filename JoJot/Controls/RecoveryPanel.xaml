<UserControl x:Class="JoJot.Controls.RecoveryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Border Background="{DynamicResource c-win-bg}" BorderBrush="{DynamicResource c-border}"
            BorderThickness="1,0,0,0">
        <Border.RenderTransform>
            <TranslateTransform x:Name="PanelTransform" X="320"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header with close button -->
            <Grid Grid.Row="0" Margin="16,16,16,8">
                <TextBlock Text="Recover Sessions" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource c-text-primary}"/>
                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           HorizontalAlignment="Right" Cursor="Hand"
                           Foreground="{DynamicResource c-text-muted}"
                           MouseLeftButtonDown="Close_Click"/>
            </Grid>

            <!-- Scrollable session list -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,16">
                <StackPanel x:Name="SessionList"/>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
