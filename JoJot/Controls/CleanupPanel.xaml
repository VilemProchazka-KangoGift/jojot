<UserControl x:Class="JoJot.Controls.CleanupPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:JoJot.Resources"
             Visibility="Collapsed">
    <Border Background="{DynamicResource c-win-bg}" BorderBrush="{DynamicResource c-border}"
            BorderThickness="1,0,0,0">
        <Border.RenderTransform>
            <TranslateTransform x:Name="PanelTransform" X="320"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Header with close button -->
            <Grid Grid.Row="0" Margin="16,16,16,8">
                <TextBlock Text="{x:Static res:Strings.Cleanup_Header}" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource c-text-primary}"/>
                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                           HorizontalAlignment="Right" Cursor="Hand"
                           Foreground="{DynamicResource c-text-muted}"
                           MouseLeftButtonDown="Close_Click"/>
            </Grid>

            <!-- Row 1: Filter controls and delete button -->
            <StackPanel Grid.Row="1" Margin="16,0,16,8">
                <!-- Filter row -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Static res:Strings.Cleanup_OlderThan}" FontSize="13"
                               Foreground="{DynamicResource c-text-primary}" VerticalAlignment="Center"/>
                    <TextBox x:Name="AgeInput" Width="45" FontSize="13" Text="7"
                             Margin="8,0,4,0" Padding="4,2" VerticalAlignment="Center"
                             Background="{DynamicResource c-editor-bg}"
                             Foreground="{DynamicResource c-text-primary}"
                             BorderBrush="{DynamicResource c-border}"
                             TextChanged="AgeInput_TextChanged"/>
                    <ComboBox x:Name="UnitCombo" FontSize="13" Width="80"
                              VerticalAlignment="Center" SelectedIndex="0"
                              SelectionChanged="UnitCombo_SelectionChanged">
                        <ComboBoxItem Content="{x:Static res:Strings.Cleanup_UnitDays}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.Cleanup_UnitHours}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.Cleanup_UnitWeeks}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.Cleanup_UnitMonths}"/>
                    </ComboBox>
                </StackPanel>
                <!-- Include pinned checkbox -->
                <CheckBox x:Name="IncludePinnedCheckbox" Content="{x:Static res:Strings.Cleanup_IncludePinned}" FontSize="13"
                          Margin="0,8,0,0" IsChecked="False"
                          Foreground="{DynamicResource c-text-primary}"
                          Checked="IncludePinned_Changed" Unchecked="IncludePinned_Changed"/>
                <!-- Delete button -->
                <Border x:Name="DeleteButton" Margin="0,12,0,0" Padding="8,6"
                        CornerRadius="4" Cursor="Hand" HorizontalAlignment="Left"
                        Background="{DynamicResource c-danger}" IsEnabled="False" Opacity="0.5"
                        MouseLeftButtonDown="Delete_Click">
                    <TextBlock x:Name="DeleteText" Text="{x:Static res:Strings.Cleanup_Delete0}" FontSize="13" Foreground="White"/>
                </Border>
            </StackPanel>

            <!-- Row 2: Scrollable preview list -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="16,0,16,8">
                <StackPanel x:Name="PreviewList"/>
            </ScrollViewer>

            <!-- Row 3: Auto-cleanup setting -->
            <StackPanel Grid.Row="3" Margin="16,0,16,16">
                <Border Height="1" Background="{DynamicResource c-border}" Margin="0,0,0,12"/>
                <TextBlock Text="{x:Static res:Strings.Pref_AutoDelete}" FontSize="13" Margin="0,0,0,6"
                           Foreground="{DynamicResource c-text-primary}"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="AutoDeleteDaysInput" Grid.Column="0"
                             Width="60" FontSize="13" Padding="6,4"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource c-tab-bg}"
                             Foreground="{DynamicResource c-text-primary}"
                             BorderBrush="{DynamicResource c-text-muted}"
                             BorderThickness="1"
                             TextChanged="AutoDeleteDays_TextChanged"
                             PreviewTextInput="AutoDeleteDays_PreviewTextInput"/>
                    <TextBlock Grid.Column="1" Text="{x:Static res:Strings.Pref_Days}" FontSize="13"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="{DynamicResource c-text-primary}"/>
                </Grid>
                <TextBlock Text="{x:Static res:Strings.Pref_AutoDeleteHint}" FontSize="11" Margin="0,2,0,0"
                           Foreground="{DynamicResource c-text-muted}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
