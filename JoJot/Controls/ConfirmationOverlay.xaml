<UserControl x:Class="JoJot.Controls.ConfirmationOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Grid>
        <!-- Semi-transparent backdrop -->
        <Border Background="#80000000" MouseLeftButtonDown="Backdrop_Click"/>

        <!-- Centered confirmation card -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource c-sidebar-bg}"
                BorderBrush="{DynamicResource c-border}" BorderThickness="1"
                CornerRadius="8" Padding="24,20" MinWidth="300" MaxWidth="400">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270"/>
            </Border.Effect>
            <StackPanel>
                <!-- Title -->
                <TextBlock x:Name="TitleText" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource c-text-primary}" Margin="0,0,0,8"/>
                <!-- Message -->
                <TextBlock x:Name="MessageText" FontSize="13" TextWrapping="Wrap"
                           Foreground="{DynamicResource c-text-muted}" Margin="0,0,0,20"/>
                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancel"
                            MinWidth="80" Height="30" Margin="0,0,8,0"
                            FontSize="13" Cursor="Hand"
                            Background="Transparent"
                            Foreground="{DynamicResource c-text-primary}"
                            BorderBrush="{DynamicResource c-border}" BorderThickness="1"
                            Click="CancelButton_Click"/>
                    <Button x:Name="DeleteButton" Content="Delete"
                            MinWidth="80" Height="30"
                            FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                            Background="#e74c3c" Foreground="White"
                            BorderThickness="0"
                            Click="DeleteButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
