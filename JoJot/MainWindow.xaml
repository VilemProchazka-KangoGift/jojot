<Window x:Class="JoJot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JoJot"
        mc:Ignorable="d"
        Title="JoJot"
        Width="500" Height="600"
        MinWidth="320" MinHeight="420"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewMouseWheel="Window_PreviewMouseWheel">
    <Window.Resources>
        <!-- ListBoxItem style: no default selection highlight, stretch content -->
        <Style TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <!-- Override default selection brushes to transparent (we handle highlighting manually) -->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Phase 7: Toolbar button style — rounded-rectangle hover background, disabled opacity -->
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HoverBorder" Background="Transparent"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBorder" Property="Background"
                                        Value="{DynamicResource c-hover-bg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource c-win-bg}"
          AllowDrop="True" DragEnter="OnFileDragEnter" DragOver="OnFileDragOver"
          DragLeave="OnFileDragLeave" Drop="OnFileDrop">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="TabPanelColumn" Width="180" MinWidth="120" MaxWidth="400"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Tab Panel (Column 0) — wrapped in Grid to allow recovery flyout overlay -->
        <Grid Grid.Column="0">
        <DockPanel Background="{DynamicResource c-sidebar-bg}">
            <!-- Header: Hamburger + Search + New Tab button -->
            <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource c-border}" Padding="6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>   <!-- Hamburger button (MENU-01) -->
                        <ColumnDefinition Width="*"/>      <!-- Search box -->
                        <ColumnDefinition Width="Auto"/>   <!-- New tab button -->
                    </Grid.ColumnDefinitions>
                    <!-- Hamburger menu button (MENU-01) -->
                    <Grid Grid.Column="0" Margin="0,0,4,0">
                        <Button x:Name="HamburgerButton" Style="{StaticResource ToolbarButtonStyle}"
                                Click="HamburgerButton_Click"
                                ToolTip="Menu" ToolTipService.InitialShowDelay="600">
                            <TextBlock Text="&#xE700;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <!-- Badge dot for orphaned sessions (ORPH-04) — wired in Plan 03 -->
                        <Ellipse x:Name="OrphanBadge" Width="7" Height="7"
                                 Fill="{DynamicResource c-accent}"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,-1,-1,0" IsHitTestVisible="False"
                                 Visibility="Collapsed"/>
                    </Grid>
                    <!-- Search box with placeholder -->
                    <Grid Grid.Column="1">
                        <TextBox x:Name="SearchBox" FontSize="12" Padding="4,2"
                                 VerticalContentAlignment="Center"
                                 Background="{DynamicResource c-sidebar-bg}"
                                 Foreground="{DynamicResource c-text-primary}"
                                 TextChanged="SearchBox_TextChanged"
                                 PreviewKeyDown="SearchBox_PreviewKeyDown"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="Search tabs..."
                                   IsHitTestVisible="False" Foreground="{DynamicResource c-text-muted}" FontSize="12"
                                   Padding="6,3" VerticalAlignment="Center"/>
                    </Grid>
                    <!-- New tab button -->
                    <Button x:Name="NewTabButton" Grid.Column="2" Content="+"
                            Width="28" Height="28" Margin="4,0,0,0"
                            FontSize="16" FontWeight="Bold"
                            Foreground="{DynamicResource c-text-muted}"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{DynamicResource c-border}" Cursor="Hand"
                            Click="NewTabButton_Click"
                            ToolTip="New tab (Ctrl+T)"/>
                </Grid>
            </Border>

            <!-- Tab list -->
            <ListBox x:Name="TabList" BorderThickness="0" Background="Transparent"
                     HorizontalContentAlignment="Stretch"
                     VirtualizingStackPanel.IsVirtualizing="False"
                     SelectionChanged="TabList_SelectionChanged"
                     PreviewKeyDown="TabList_PreviewKeyDown"
                     PreviewMouseDoubleClick="TabList_PreviewMouseDoubleClick"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
        </DockPanel>

        <!-- Recovery panel placeholder (modal is in the root Grid) -->
        </Grid>

        <!-- Resizable separator (Column 1) — Phase 12: TABUX-04 -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      VerticalAlignment="Stretch" Background="{DynamicResource c-border}"
                      Cursor="SizeWE" ResizeBehavior="PreviousAndNext"
                      DragCompleted="TabPanelSplitter_DragCompleted"/>

        <!-- Content Area (Column 2) — toolbar + editor + toast -->
        <Grid Grid.Column="2" ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Toolbar (Row 0) — TOOL-01, TOOL-02, TOOL-03 -->
            <Border Grid.Row="0" BorderThickness="0,0,0,1"
                    BorderBrush="{DynamicResource c-border}"
                    Background="{DynamicResource c-win-bg}"
                    Padding="4,2">
                <DockPanel>
                    <!-- Delete button — right-aligned via DockPanel.Dock="Right" (TOOL-02) -->
                    <Button x:Name="ToolbarDelete" DockPanel.Dock="Right"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Click="ToolbarDelete_Click"
                            ToolTip="Delete (Ctrl+W)" ToolTipService.InitialShowDelay="600">
                        <TextBlock x:Name="DeleteIconText" Text="&#xE74D;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="14" Foreground="#e74c3c" Opacity="0.7"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Left-aligned buttons -->
                    <StackPanel Orientation="Horizontal">
                        <!-- Undo -->
                        <Button x:Name="ToolbarUndo" Style="{StaticResource ToolbarButtonStyle}"
                                Click="ToolbarUndo_Click"
                                ToolTip="Undo (Ctrl+Z)" ToolTipService.InitialShowDelay="600">
                            <TextBlock Text="&#xE7A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Redo -->
                        <Button x:Name="ToolbarRedo" Style="{StaticResource ToolbarButtonStyle}"
                                Click="ToolbarRedo_Click"
                                ToolTip="Redo (Ctrl+Y)" ToolTipService.InitialShowDelay="600">
                            <TextBlock Text="&#xE7A6;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Separator -->
                        <Border Width="1" Margin="4,4" Background="{DynamicResource c-border}"/>

                        <!-- Pin -->
                        <Button x:Name="ToolbarPin" Style="{StaticResource ToolbarButtonStyle}"
                                Click="ToolbarPin_Click"
                                ToolTip="Pin (Ctrl+P)" ToolTipService.InitialShowDelay="600">
                            <TextBlock x:Name="PinIconText" Text="&#xE718;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Clone -->
                        <Button x:Name="ToolbarClone" Style="{StaticResource ToolbarButtonStyle}"
                                Click="ToolbarClone_Click"
                                ToolTip="Clone to new tab (Ctrl+K)" ToolTipService.InitialShowDelay="600">
                            <TextBlock Text="&#xF413;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Separator -->
                        <Border Width="1" Margin="4,4" Background="{DynamicResource c-border}"/>

                        <!-- Copy -->
                        <Button x:Name="ToolbarCopy" Style="{StaticResource ToolbarButtonStyle}"
                                Click="ToolbarCopy_Click"
                                ToolTip="Copy (Ctrl+C)" ToolTipService.InitialShowDelay="600">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Paste -->
                        <Button x:Name="ToolbarPaste" Style="{StaticResource ToolbarButtonStyle}"
                                Click="ToolbarPaste_Click"
                                ToolTip="Paste (Ctrl+V)" ToolTipService.InitialShowDelay="600">
                            <TextBlock Text="&#xE77F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>

                        <!-- Separator -->
                        <Border Width="1" Margin="4,4" Background="{DynamicResource c-border}"/>

                        <!-- Save as TXT -->
                        <Button x:Name="ToolbarSave" Style="{StaticResource ToolbarButtonStyle}"
                                Click="ToolbarSave_Click"
                                ToolTip="Save as TXT (Ctrl+S)" ToolTipService.InitialShowDelay="600">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Editor + Find Bar + Toast (Row 1) -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox x:Name="ContentEditor" Grid.Row="0"
                         AcceptsReturn="True" AcceptsTab="True"
                         TextWrapping="Wrap" FontFamily="Consolas" FontSize="13"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0" Padding="12,8"
                         Background="{DynamicResource c-editor-bg}"
                         Foreground="{DynamicResource c-text-primary}"
                         CaretBrush="{DynamicResource c-text-primary}"
                         IsUndoEnabled="False"
                         IsEnabled="False"/>

                <!-- Phase 9: Font size tooltip (KEYS-02) — auto-dismissing overlay -->
                <Border x:Name="FontSizeTooltip" Visibility="Collapsed" Background="#CC333333"
                        CornerRadius="4" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,8,8,0" Panel.ZIndex="60" IsHitTestVisible="False">
                    <TextBlock x:Name="FontSizeTooltipText" FontSize="12" Foreground="White"/>
                </Border>

                <!-- Phase 9: In-editor find bar (Ctrl+F when editor focused) -->
                <Grid x:Name="EditorFindBar" Grid.Row="1" Visibility="Collapsed"
                      Background="{DynamicResource c-tab-bg}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="EditorFindInput" Grid.Column="0" FontSize="13" Padding="6,4"
                             Background="{DynamicResource c-win-bg}" Foreground="{DynamicResource c-text-primary}"
                             BorderBrush="{DynamicResource c-text-muted}" BorderThickness="1" Margin="8,4"
                             TextChanged="EditorFindInput_TextChanged"
                             PreviewKeyDown="EditorFindInput_PreviewKeyDown"/>
                    <TextBlock x:Name="EditorFindCount" Grid.Column="1" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource c-text-muted}" Margin="0,0,8,0"/>
                    <Border Grid.Column="2" Cursor="Hand" Padding="4,2" Margin="2" CornerRadius="3"
                            MouseLeftButtonDown="EditorFindPrevious_Click">
                        <TextBlock Text="&#xE70E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource c-text-primary}"/>
                    </Border>
                    <Border Grid.Column="3" Cursor="Hand" Padding="4,2" Margin="2" CornerRadius="3"
                            MouseLeftButtonDown="EditorFindNext_Click">
                        <TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource c-text-primary}"/>
                    </Border>
                    <Border Grid.Column="4" Cursor="Hand" Padding="4,2" Margin="2,0,8,0" CornerRadius="3"
                            MouseLeftButtonDown="EditorFindClose_Click">
                        <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{DynamicResource c-text-muted}"/>
                    </Border>
                </Grid>

                <!-- Toast notification overlay (Phase 5: soft-delete undo) -->
                <Border x:Name="ToastBorder" Grid.Row="0"
                        VerticalAlignment="Bottom" Height="36"
                        Background="{DynamicResource c-toast-bg}" Visibility="Collapsed"
                        Panel.ZIndex="10">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ToastTranslate" Y="36"/>
                    </Border.RenderTransform>
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ToastMessageBlock" Grid.Column="0"
                                   VerticalAlignment="Center" Foreground="{DynamicResource c-toast-fg}" FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="UndoButton" Grid.Column="1" VerticalAlignment="Center"
                                   Foreground="{DynamicResource c-accent}" FontSize="13"
                                   TextDecorations="Underline" Cursor="Hand"
                                   Margin="12,0,0,0"
                                   MouseLeftButtonDown="UndoToast_Click">
                            Undo
                        </TextBlock>
                    </Grid>
                </Border>

            </Grid>
        </Grid>

        <!-- R2-DROP-01: File drop overlay moved to root Grid level for full-window coverage -->
        <Grid x:Name="FileDropOverlay" Grid.ColumnSpan="3" Visibility="Collapsed"
              Background="#80000000" Panel.ZIndex="50"
              AllowDrop="True" DragOver="OnFileDragOver" Drop="OnFileDrop">
            <Border BorderBrush="{DynamicResource c-accent}" BorderThickness="3" CornerRadius="8" Margin="16">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="48"
                               Foreground="{DynamicResource c-accent}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Drop file here" FontSize="18" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Text files only, max 500KB" FontSize="12"
                               Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Hamburger menu popup (MENU-01) -->
        <Popup x:Name="HamburgerMenu" StaysOpen="False" AllowsTransparency="True"
               PlacementTarget="{Binding ElementName=HamburgerButton}"
               Placement="Bottom" HorizontalOffset="-4" VerticalOffset="2">
            <Border Background="{DynamicResource c-sidebar-bg}"
                    BorderBrush="{DynamicResource c-border}" BorderThickness="1"
                    CornerRadius="6" Padding="4" MinWidth="220">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" Opacity="0.25" ShadowDepth="4" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Recover sessions -->
                    <Border x:Name="MenuRecover" Padding="8,6" Cursor="Hand" Background="Transparent"
                            MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                            MouseLeftButtonDown="MenuRecover_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="MenuRecoverText" Grid.Column="1" Text="Recover sessions" FontSize="13"
                                       Foreground="{DynamicResource c-text-primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Separator -->
                    <Separator Margin="4,2" Background="{DynamicResource c-border}"/>

                    <!-- Delete older than (with submenu) -->
                    <Border x:Name="MenuDeleteOlder" Padding="8,6" Cursor="Hand" Background="Transparent"
                            MouseEnter="MenuDeleteOlder_MouseEnter" MouseLeave="MenuDeleteOlder_MouseLeave"
                            MouseLeftButtonDown="MenuDeleteOlder_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE81C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Delete older than..." FontSize="13"
                                       Foreground="{DynamicResource c-text-primary}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="&#xE76C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="10" Foreground="{DynamicResource c-text-muted}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </Grid>
                    </Border>

                    <!-- Delete older than submenu popup (right-side flyout) -->
                    <Popup x:Name="DeleteOlderSubmenu" StaysOpen="True" AllowsTransparency="True"
                           PlacementTarget="{Binding ElementName=MenuDeleteOlder}"
                           Placement="Right" HorizontalOffset="0" VerticalOffset="-6">
                        <Border Background="{DynamicResource c-sidebar-bg}"
                                BorderBrush="{DynamicResource c-border}" BorderThickness="1"
                                CornerRadius="6" Padding="4" MinWidth="140"
                                MouseLeave="SubmenuBorder_MouseLeave">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8" Opacity="0.2" ShadowDepth="3" Direction="270"/>
                            </Border.Effect>
                            <StackPanel>
                                <Border Padding="8,5" Cursor="Hand" Background="Transparent"
                                        MouseEnter="SubmenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                                        MouseLeftButtonDown="MenuDeleteOlder7_Click">
                                    <TextBlock Text="7 days" FontSize="13" Foreground="{DynamicResource c-text-primary}"/>
                                </Border>
                                <Border Padding="8,5" Cursor="Hand" Background="Transparent"
                                        MouseEnter="SubmenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                                        MouseLeftButtonDown="MenuDeleteOlder14_Click">
                                    <TextBlock Text="14 days" FontSize="13" Foreground="{DynamicResource c-text-primary}"/>
                                </Border>
                                <Border Padding="8,5" Cursor="Hand" Background="Transparent"
                                        MouseEnter="SubmenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                                        MouseLeftButtonDown="MenuDeleteOlder30_Click">
                                    <TextBlock Text="30 days" FontSize="13" Foreground="{DynamicResource c-text-primary}"/>
                                </Border>
                                <Border Padding="8,5" Cursor="Hand" Background="Transparent"
                                        MouseEnter="SubmenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                                        MouseLeftButtonDown="MenuDeleteOlder90_Click">
                                    <TextBlock Text="90 days" FontSize="13" Foreground="{DynamicResource c-text-primary}"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Delete all except pinned -->
                    <Border x:Name="MenuDeleteExceptPinned" Padding="8,6" Cursor="Hand" Background="Transparent"
                            MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                            MouseLeftButtonDown="MenuDeleteExceptPinned_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Delete all except pinned" FontSize="13"
                                       Foreground="{DynamicResource c-text-primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Delete all -->
                    <Border x:Name="MenuDeleteAll" Padding="8,6" Cursor="Hand" Background="Transparent"
                            MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                            MouseLeftButtonDown="MenuDeleteAll_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE75C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="#e74c3c" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Delete all" FontSize="13"
                                       Foreground="{DynamicResource c-text-primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Separator -->
                    <Separator Margin="4,2" Background="{DynamicResource c-border}"/>

                    <!-- Preferences -->
                    <Border x:Name="MenuPreferences" Padding="8,6" Cursor="Hand" Background="Transparent"
                            MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                            MouseLeftButtonDown="MenuPreferences_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Preferences" FontSize="13"
                                       Foreground="{DynamicResource c-text-primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Exit -->
                    <Border x:Name="MenuExit" Padding="8,6" Cursor="Hand" Background="Transparent"
                            MouseEnter="MenuItem_MouseEnter" MouseLeave="MenuItem_MouseLeave"
                            MouseLeftButtonDown="MenuExit_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE7E8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="14" Foreground="{DynamicResource c-toolbar-icon}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Exit" FontSize="13"
                                       Foreground="{DynamicResource c-text-primary}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Bulk delete confirmation overlay (Phase 8: MENU-03, MENU-04, MENU-05) -->
        <Grid x:Name="ConfirmationOverlay" Visibility="Collapsed" Panel.ZIndex="100"
              Grid.ColumnSpan="3">
            <!-- Semi-transparent backdrop -->
            <Border Background="#80000000" MouseLeftButtonDown="ConfirmOverlayBackdrop_Click"/>

            <!-- Centered confirmation card -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource c-sidebar-bg}"
                    BorderBrush="{DynamicResource c-border}" BorderThickness="1"
                    CornerRadius="8" Padding="24,20" MinWidth="300" MaxWidth="400">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Title -->
                    <TextBlock x:Name="ConfirmTitle" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource c-text-primary}" Margin="0,0,0,8"/>
                    <!-- Message -->
                    <TextBlock x:Name="ConfirmMessage" FontSize="13" TextWrapping="Wrap"
                               Foreground="{DynamicResource c-text-muted}" Margin="0,0,0,20"/>
                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="ConfirmCancelButton" Content="Cancel"
                                MinWidth="80" Height="30" Margin="0,0,8,0"
                                FontSize="13" Cursor="Hand"
                                Background="Transparent"
                                Foreground="{DynamicResource c-text-primary}"
                                BorderBrush="{DynamicResource c-border}" BorderThickness="1"
                                Click="ConfirmCancel_Click"/>
                        <Button x:Name="ConfirmDeleteButton" Content="Delete"
                                MinWidth="80" Height="30"
                                FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                Background="#e74c3c" Foreground="White"
                                BorderThickness="0"
                                Click="ConfirmDelete_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <!-- Phase 10: Lock overlay for window drag resolution (DRAG-03) -->
        <Grid x:Name="DragOverlay" Visibility="Collapsed" Panel.ZIndex="200"
              Grid.ColumnSpan="3">
            <!-- Semi-transparent backdrop (DRAG-03: rgba 0,0,0,0.65) -->
            <Border Background="#A6000000" />

            <!-- Centered card -->
            <Border Background="{DynamicResource c-win-bg}"
                    CornerRadius="8" Padding="32,24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="360" MaxWidth="480">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" Opacity="0.3" ShadowDepth="6" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- R2-MOVE-01: Source desktop name -->
                    <TextBlock x:Name="DragOverlaySourceName"
                               FontSize="11"
                               Foreground="{DynamicResource c-text-muted}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,4" />

                    <!-- Context message -->
                    <TextBlock x:Name="DragOverlayTitle"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource c-text-primary}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8" />
                    <TextBlock x:Name="DragOverlayMessage"
                               FontSize="13"
                               Foreground="{DynamicResource c-text-muted}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Button x:Name="DragKeepHereBtn"
                                Content="Keep here"
                                Click="DragKeepHere_Click"
                                Padding="16,8" Margin="0,0,8,0"
                                FontSize="13"
                                Background="{DynamicResource c-accent}"
                                Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand" />
                        <Button x:Name="DragMergeBtn"
                                Content="Merge notes"
                                Click="DragMerge_Click"
                                Padding="16,8" Margin="0,0,8,0"
                                FontSize="13"
                                Background="{DynamicResource c-tab-bg}"
                                Foreground="{DynamicResource c-text-primary}"
                                BorderBrush="{DynamicResource c-border}"
                                BorderThickness="1"
                                Cursor="Hand" />
                        <Button x:Name="DragCancelBtn"
                                Content="Go back"
                                Click="DragCancel_Click"
                                Padding="16,8"
                                FontSize="13"
                                Background="{DynamicResource c-tab-bg}"
                                Foreground="{DynamicResource c-text-primary}"
                                BorderBrush="{DynamicResource c-border}"
                                BorderThickness="1"
                                Cursor="Hand" />
                    </StackPanel>

                    <!-- Cancel failure instruction (DRAG-07) — hidden by default -->
                    <TextBlock x:Name="DragCancelFailureText"
                               Text="If retry fails, move this window back manually via Win+Tab"
                               FontSize="11"
                               Foreground="{DynamicResource c-text-muted}"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </Grid>
        <!-- Phase 9: Preferences slide-in panel (PREF-01 through PREF-05) -->
        <Border x:Name="PreferencesPanel" Width="300" HorizontalAlignment="Right"
                Background="{DynamicResource c-win-bg}" BorderBrush="{DynamicResource c-border}"
                BorderThickness="1,0,0,0" Visibility="Collapsed" Panel.ZIndex="80"
                Grid.ColumnSpan="3">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PrefPanelTransform" X="300"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header with close button -->
                <Grid Grid.Row="0" Margin="16,16,16,8">
                    <TextBlock Text="Preferences" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource c-text-primary}"/>
                    <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                               HorizontalAlignment="Right" Cursor="Hand"
                               Foreground="{DynamicResource c-text-muted}"
                               MouseLeftButtonDown="ClosePreferences_Click"/>
                </Grid>

                <!-- Scrollable content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,16">
                    <StackPanel>
                        <!-- APPEARANCE SECTION -->
                        <TextBlock Text="APPEARANCE" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,8"
                                   Foreground="{DynamicResource c-text-muted}"/>

                        <!-- Theme toggle (PREF-02) -->
                        <TextBlock Text="Theme" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{DynamicResource c-text-primary}"/>
                        <Grid x:Name="ThemeToggle" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="ThemeLightBtn" Grid.Column="0" CornerRadius="4,0,0,4"
                                    BorderThickness="1" BorderBrush="{DynamicResource c-border}"
                                    Cursor="Hand" Padding="8,6"
                                    MouseLeftButtonDown="ThemeLight_Click">
                                <TextBlock Text="Light" FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource c-text-primary}"/>
                            </Border>
                            <Border x:Name="ThemeSystemBtn" Grid.Column="1"
                                    BorderThickness="0,1,0,1" BorderBrush="{DynamicResource c-border}"
                                    Cursor="Hand" Padding="8,6"
                                    MouseLeftButtonDown="ThemeSystem_Click">
                                <TextBlock Text="System" FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource c-text-primary}"/>
                            </Border>
                            <Border x:Name="ThemeDarkBtn" Grid.Column="2" CornerRadius="0,4,4,0"
                                    BorderThickness="1" BorderBrush="{DynamicResource c-border}"
                                    Cursor="Hand" Padding="8,6"
                                    MouseLeftButtonDown="ThemeDark_Click">
                                <TextBlock Text="Dark" FontSize="12" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource c-text-primary}"/>
                            </Border>
                        </Grid>

                        <!-- Font size (PREF-03) -->
                        <TextBlock Text="Font Size" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{DynamicResource c-text-primary}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="4" BorderThickness="1"
                                    BorderBrush="{DynamicResource c-text-muted}" Cursor="Hand"
                                    Padding="10,4" MouseLeftButtonDown="FontSizeDecrease_Click">
                                <TextBlock Text="-" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource c-text-primary}" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="FontSizeDisplay" Grid.Column="1" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource c-text-primary}"/>
                            <Border Grid.Column="2" CornerRadius="4" BorderThickness="1"
                                    BorderBrush="{DynamicResource c-text-muted}" Cursor="Hand"
                                    Padding="10,4" MouseLeftButtonDown="FontSizeIncrease_Click">
                                <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource c-text-primary}" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="100%" FontSize="11" Foreground="{DynamicResource c-accent}"
                                   Cursor="Hand" Margin="0,2,0,16" HorizontalAlignment="Center"
                                   MouseLeftButtonDown="FontSizeReset_Click"
                                   TextDecorations="Underline"/>

                        <!-- SHORTCUTS SECTION (R2-PREF-01: Editor/autosave section removed) -->
                        <TextBlock Text="SHORTCUTS" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,8"
                                   Foreground="{DynamicResource c-text-muted}"/>

                        <!-- Global hotkey picker (PREF-05) -->
                        <TextBlock Text="Global Hotkey" FontSize="13" Margin="0,0,0,6"
                                   Foreground="{DynamicResource c-text-primary}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="4" BorderThickness="1"
                                    BorderBrush="{DynamicResource c-text-muted}" Padding="8,4"
                                    Background="{DynamicResource c-tab-bg}">
                                <TextBlock x:Name="HotkeyDisplay" FontSize="13"
                                           Foreground="{DynamicResource c-text-primary}"/>
                            </Border>
                            <Border x:Name="HotkeyRecordBtn" Grid.Column="1" CornerRadius="4" Cursor="Hand"
                                    Background="{DynamicResource c-accent}" Padding="12,4" Margin="8,0,0,0"
                                    MouseLeftButtonDown="HotkeyRecord_Click">
                                <TextBlock x:Name="HotkeyRecordText" Text="Record" FontSize="12"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Focus JoJot from any app" FontSize="11" Margin="0,2,0,16"
                                   Foreground="{DynamicResource c-text-muted}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Phase 9: Help overlay — keyboard shortcuts reference (Ctrl+?) -->
        <Grid x:Name="HelpOverlay" Visibility="Collapsed" Background="#CC000000" Panel.ZIndex="200"
              Grid.ColumnSpan="3" MouseLeftButtonDown="HelpOverlay_Click">
            <Border Background="{DynamicResource c-win-bg}" CornerRadius="8" Padding="24"
                    MaxWidth="500" MaxHeight="600" HorizontalAlignment="Center" VerticalAlignment="Center"
                    MouseLeftButtonDown="HelpCard_Click">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="HelpContent">
                        <Grid>
                            <TextBlock Text="Keyboard Shortcuts" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{DynamicResource c-text-primary}"/>
                            <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                                       HorizontalAlignment="Right" Cursor="Hand"
                                       Foreground="{DynamicResource c-text-muted}"
                                       MouseLeftButtonDown="HelpClose_Click"/>
                        </Grid>
                        <TextBlock Text="Press Escape or click outside to close" FontSize="11"
                                   Foreground="{DynamicResource c-text-muted}" Margin="0,4,0,16"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Recovery sidebar (R2-RECOVER-01) — slide-in from right, same pattern as PreferencesPanel -->
        <Border x:Name="RecoveryPanel" Width="320" HorizontalAlignment="Right"
                Background="{DynamicResource c-win-bg}" BorderBrush="{DynamicResource c-border}"
                BorderThickness="1,0,0,0" Visibility="Collapsed" Panel.ZIndex="85"
                Grid.ColumnSpan="3">
            <Border.RenderTransform>
                <TranslateTransform x:Name="RecoveryPanelTransform" X="320"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header with close button -->
                <Grid Grid.Row="0" Margin="16,16,16,8">
                    <TextBlock Text="Recover Sessions" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource c-text-primary}"/>
                    <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14"
                               HorizontalAlignment="Right" Cursor="Hand"
                               Foreground="{DynamicResource c-text-muted}"
                               MouseLeftButtonDown="RecoveryClose_Click"/>
                </Grid>

                <!-- Scrollable session list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,16">
                    <StackPanel x:Name="RecoverySessionList"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
